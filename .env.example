# ── Endpoint ──────────────────────────────────────────────────────────────────
# OpenAI (default, leave OPENAI_BASE_URL unset)
OPENAI_API_KEY=sk-...
ORGANIZATION_ID=org-...

# OpenRouter (set base_url, remove ORGANIZATION_ID)
# OPENAI_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Model roles ───────────────────────────────────────────────────────────────
# scientist: SCM design, agent building, data analysis
LLM_SCIENTIST_FAMILY=openai
LLM_SCIENTIST_MODEL=gpt-4

# subject: simulation agents in conversations
LLM_SUBJECT_FAMILY=openai
LLM_SUBJECT_MODEL=gpt-4

# Mix example: cheap model for subjects, strong model for scientist
# LLM_SCIENTIST_FAMILY=openai
# LLM_SCIENTIST_MODEL=gpt-4
# LLM_SUBJECT_FAMILY=openrouter
# LLM_SUBJECT_MODEL=deepseek/deepseek-v3.2
